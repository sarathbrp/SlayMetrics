# SlayMetrics Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── LLM (required) ───────────────────────────────────────────────
GPT_OSS_BASE_URL=http://your-gpt-oss-host:8002/v1
GPT_OSS_API_KEY=your-api-key-here
GPT_OSS_MODEL=/models/gpt-oss-120b
GPT_OSS_EMBED_MODEL=                         # optional, defaults to GPT_OSS_MODEL

# ─── Target DUT (override config.yaml target section) ─────────────
SLAY_DUT_HOST=172.21.90.178
SLAY_DUT_USER=root
SLAY_DUT_KEY=/root/.ssh/id_ed25519
SLAY_DUT_PORT=22
SLAY_DUT_TIMEOUT=30

# ─── MLflow (override config.yaml mlflow section) ─────────────────
SLAY_MLFLOW_ENABLED=true
SLAY_MLFLOW_URI=http://localhost:5000
SLAY_MLFLOW_EXPERIMENT=SlayMetrics
