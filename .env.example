# Copy this to .env and fill in your values
# cp .env.example .env

# Optional: only needed for claude-api profile
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model profiles used by config.yaml:
#   granite-api -> granite4:7b-a1b-h
#   gpt-oss-api -> gpt-oss-120b via OpenAI-compatible API
#   claude-api -> claude-opus-4-6

# GPT-OSS deployment
# GPT_OSS_BASE_URL=http://your-gpt-oss-host:8002/v1
# GPT_OSS_API_KEY=your-gpt-oss-token-here

# DUT (Device Under Test) — the system running nginx
DUT_HOST=172.21.90.178

# Contestant name for hackathon benchmark results
CONTESTANT_NAME=slaymetrics

# Optional: TiDB password (empty for local tiup playground)
# TIDB_PASSWORD=
