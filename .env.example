# Copy this to .env and fill in your values
# cp .env.example .env

# Required for claude-haiku / claude-remote profile
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DUT (Device Under Test) — the system running nginx
DUT_HOST=192.168.1.100

# Optional: TiDB password (empty for local tiup playground)
# TIDB_PASSWORD=
